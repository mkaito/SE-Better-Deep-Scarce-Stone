#!/usr/bin/env bash
#MISE description="Stage mod files into Upload/ for Steam Workshop publishing."
set -euo pipefail
IFS=$'\n\t'

cd "$MISE_PROJECT_ROOT"

: "${SE_DATA:?SE_DATA must point to SE Content/Data (set in mise.toml).}"
[[ -d "$SE_DATA/PlanetDataFiles" ]] || {
    echo "SE_DATA=$SE_DATA: PlanetDataFiles directory not found." >&2
    exit 1
}

[[ -d vendor/POG/PlanetDataFiles ]] || {
    echo "vendor/POG/PlanetDataFiles missing. Run 'mise run oregen' first." >&2
    exit 1
}

rm -rf ./Upload
mkdir -p ./Upload/Data

echo '** Copying vanilla planet data files'
rsync -rt \
    --exclude='*Tutorial/' \
    --exclude='SystemTestMap/' \
    "$SE_DATA/PlanetDataFiles" ./Upload/Data/

echo '** Merging ore generator output'
rsync -rt --exclude='*_coloured.png' vendor/POG/PlanetDataFiles ./Upload/Data/
cp vendor/POG/*.sbc ./Upload/Data/

echo '** Merging manual overrides'
rsync -rtL ./Assets/ ./Upload/
rsync -rtL ./Data/ ./Upload/Data/

echo '** Copying sky textures referenced by planet defs'
# SE Linux fails to resolve some vanilla sky textures (case-sensitive _Alphamask;
# Landsky_texture/TritonAurora _cm). Mod-folder copies override game-folder lookup.
# See doc/build-pipeline.md.
SE_SKY="$SE_DATA/../Textures/Models/Environment/Sky"
if [[ -d "$SE_SKY" ]]; then
    mkdir -p ./Upload/Textures/Models/Environment/Sky
    mapfile -t stems < <(
        grep -oE 'Sky/[A-Za-z0-9_]+\.dds' ./Upload/Data/PlanetGeneratorDefinitions.sbc \
            | sed -E 's|Sky/||; s|\.dds$||' | sort -u
    )
    for stem in "${stems[@]}"; do
        for suffix in _cm _alphamask _Alphamask; do
            src="$SE_SKY/${stem}${suffix}.dds"
            [[ -f "$src" ]] || continue
            target_suffix="${suffix,,}"
            cp "$src" "./Upload/Textures/Models/Environment/Sky/${stem}${target_suffix}.dds"
        done
    done
else
    echo "warning: $SE_SKY not found; skipping sky texture copy" >&2
fi

echo "Staged to ./Upload"
