#!/usr/bin/env bash
#MISE description="Generate ore maps with Procedural Ore Generator. Outputs to vendor/POG/PlanetDataFiles/."
#MISE depends=["genconfig"]
set -euo pipefail
IFS=$'\n\t'

cd "$MISE_PROJECT_ROOT"

: "${SE_DATA:?SE_DATA must point to SE Content/Data (set in mise.toml).}"
[[ -d "$SE_DATA/PlanetDataFiles" ]] || {
    echo "SE_DATA=$SE_DATA: PlanetDataFiles directory not found." >&2
    exit 1
}
[[ -f "$SE_DATA/PlanetGeneratorDefinitions.sbc" ]] || {
    echo "SE_DATA=$SE_DATA: PlanetGeneratorDefinitions.sbc not found." >&2
    exit 1
}

# POG reads ./config.json and ./lib/* from cwd.
envsubst <pog-config.json.template >vendor/POG/config.json

cd vendor/POG
# Empty stdin satisfies POG's "press ENTER" prompt.
java -Xms512m -Xmx4g -cp 'Procedural_Ore_Generator.jar:lib/*' core.Main <<<""

cd "$MISE_PROJECT_ROOT"
# Convert to markdown + prettier-normalize (else next pre-commit churns the file).
.mise/tasks/poglog2md.py
prettier --write doc/ore-deposit-counts.md >/dev/null
