#!/usr/bin/env bash
#MISE description="Build and publish the mod to Steam Workshop."
#MISE depends=["build"]
set -euo pipefail
IFS=$'\n\t'

cd "$MISE_PROJECT_ROOT"

pandoc -f markdown -t ./vendor/2bbcode/bbcode_steam.lua readme.md >|description.bb

# Workshop description hard cap.
[[ $(wc -c <description.bb) -le 7999 ]] || { echo "description.bb >8000 bytes"; exit 1; }

MOD_ID=2724252237

cat <<EOF >|mod.vdf
"workshopitem"
{
  "appid"             "244850"
  "publishedfileid"   "$MOD_ID"
  "contentfolder"     "$PWD/Upload"
  "description"       "$(cat "$PWD/description.bb")"
}
EOF

: "${STEAMPASSWORD:?STEAMPASSWORD must be set in the environment.}"
: "${STEAMCMD:?STEAMCMD must point to a steamcmd entry point (set in mise.toml).}"

"$STEAMCMD" \
    +login mkaito "$STEAMPASSWORD" \
    +workshop_build_item "$(readlink -f ./mod.vdf)" \
    +quit
