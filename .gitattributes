# Default: treat all text as LF in repo and in working tree.
* text=auto eol=lf

# Explicit text types (defensive, in case auto-detection misses).
*.sbc       text eol=lf
*.xml       text eol=lf
*.bb        text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.lua       text eol=lf

# Windows-flavoured scripts that genuinely need CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary assets — never touch.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.psd       binary
*.dds       binary
*.jar       binary
*.zip       binary
